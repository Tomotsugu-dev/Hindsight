# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Tauri / Rust
src-tauri/target/
src-tauri/gen/schemas/

# Vite 缓存
.vite/

# release script 临时产物（每次 npm run release 都会重写，没必要 track）
/latest.json

# 一次性脚本输出（dedupe_today_screenshots.py 等）
test_screenshots/

# 签名私钥 / 证书：永远不要提交。Tauri updater 用 ~/.tauri/*.key，CI 走 secret。
*.key
*.pem
*.p12

# onnxruntime 动态库（~30 MB）：开发者跑 src-tauri/scripts/fetch-onnxruntime.* 拉取
src-tauri/resources/runtime/*.dll
src-tauri/resources/runtime/*.so
src-tauri/resources/runtime/*.so.*
src-tauri/resources/runtime/*.dylib

# README 软件预览
docs/intro_zh/imgs/Hindsight_zh.mp4
docs/intro_en/imgs/Hindsight_en.mp4

# 内部 doc / TODO / 多设备测试笔记，仅本地保留不入仓
docs/internal/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python test cache
__pycache__/
*.pyc
.pytest_cache/

# Python Files
*.py
# 例外:scripts/poc/ 评测脚本入仓(其产物 output/ 仍忽略,含真实截图)
!scripts/poc/*.py
# 例外:演示数据生成器入仓(生成的数据在 app 数据目录,不在仓库)
!scripts/demo/*.py
.python-version
pyproject.toml
uv.lock
.venv/
similarity-poc/

# Claude
.claude/

# deploy doc
web/README-pi.md

# 设计原型 / 草稿 HTML：本地预览用，不入仓
prototypes/

# demo 构建产物：由 Cloudflare Pages 部署时 `npm ci && npm run build:demo` 重新生成，不入仓
web/demo/


# POC 输出（含真实屏幕内容，勿提交）
scripts/poc/output/
