{
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/dist-ssr": true,
    "**/.vite": true,
    "src-tauri/target": true,
    "src-tauri/gen": true,
    "src-tauri/icons": true,
    "src-tauri/Cargo.lock": true,
    "src-tauri/build.rs": true,
    "src-tauri/.gitignore": true,
    ".gitignore": false,
    "package-lock.json": true,
    "tsconfig.node.json": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    ".python-version": true,
    "pyproject.toml": true,
    "uv.lock": true,
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/dist-ssr": true,
    "**/.vite": true,
    "src-tauri/target": true,
    "src-tauri/gen/schemas": true,
    "package-lock.json": true,
    "src-tauri/Cargo.lock": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/*.py": true,
    "uv.lock": true,
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.vite/**": true,
    "src-tauri/target/**": true
  }
}
