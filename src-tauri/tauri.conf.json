{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hindsight",
  "version": "0.8.6-beta.2",
  "identifier": "com.tomotsugu.hindsight",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:41420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hindsight",
        "width": 960,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "maxWidth": 960,
        "maxHeight": 820,
        "resizable": true,
        "maximizable": false,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data: blob: https://cdn-avatars.huggingface.co",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "media-src": "'self' asset: http://asset.localhost",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data: blob: https://cdn-avatars.huggingface.co",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:41420 http://localhost:41420",
        "media-src": "'self' asset: http://asset.localhost",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Tomotsugu-dev/Hindsight/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2RTc4NERGREUwNzM0OUUKUldTZU5BZmUzNFRuSmsyRDZBN1l4UWRpOVNldzRyd1BSNllMUjA5WlRZL2xFVjI1RDFrb0UyUUMK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "app", "deb", "rpm", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer_hooks.nsh",
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "signingIdentity": "Developer ID Application: Youyan Xu (HJ2YT95D35)",
      "providerShortName": "HJ2YT95D35",
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "14.0"
    }
  }
}
